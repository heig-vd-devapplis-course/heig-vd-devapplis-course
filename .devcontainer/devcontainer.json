{
	"name": "HEIG-VD DévAppliS Course Development Container",
	"dockerComposeFile": "compose.yaml",
	"service": "devcontainer",
	"runServices": ["plantuml"],
	"workspaceFolder": "/workspace",
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:3.0.1": {
			"moby": false
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"DavidAnson.vscode-markdownlint",
				"esbenp.prettier-vscode",
				"GitHub.copilot",
				"jebbs.plantuml",
				"marp-team.marp-vscode",
				"redhat.vscode-yaml",
				"streetsidesoftware.code-spell-checker",
				"streetsidesoftware.code-spell-checker-french",
				"tomoki1207.pdf",
				"yzhang.markdown-all-in-one"
			]
		}
	},
	// Ports to expose on the container's network host
	"forwardPorts": [9090],
	"portsAttributes": {
		"9090": {
			"label": "PlantUML Server"
		}
	},
	// Execute the post-create.sh script once the container is created
	"postCreateCommand": ".devcontainer/post-create.sh"
}
